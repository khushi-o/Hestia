# Copy to .env.local for local overrides (see Vite docs). Values are baked in at build time.

# API base URL including /api (must match how routes are mounted on the server)
VITE_API_URL=http://localhost:5000/api

# Optional: Socket.io origin (defaults to the same host as VITE_API_URL without /api)
# VITE_SOCKET_URL=http://localhost:5000

# Optional: show “Try the demo” on the login page in production builds (after you seed demo users on your API’s database). Omit or false = hidden on prod; dev server always shows it.
# VITE_SHOW_DEMO_LOGIN=true
